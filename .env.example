#############################
# Core app
#############################
API_BASE_URL=http://localhost:8000

#############################
# LLM provider
# Values: ollama | gemini
#############################
LLM_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:latest

#############################
# Embeddings provider
# Values: ollama | gemini
#############################
EMBEDDINGS_PROVIDER=ollama
EMBEDDING_MODEL=gemini-embedding-001
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

#############################
# Crawl provider
#############################
TAVILY_API_KEY=

#############################
# Vector store
#############################
PINECONE_API_KEY=
INDEX_NAME=documentation-helper

#############################
# Chunking and indexing
#############################
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
BATCH_SIZE=50

#############################
# Retrieval guardrails
#############################
MIN_SOURCES=1
MIN_TOP_SCORE=0.3
NOTE_SCORE_THRESHOLD=0.6
NOTE_SCORE_MARGIN=0.05

#############################
# RabbitMQ
#############################
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_INGEST=ingest
RABBITMQ_EXCHANGE_DEAD_LETTER=ingest.dead_letter
RABBITMQ_QUEUE_INGEST_FAILED=ingest.failed

#############################
# Worker behavior
#############################
WORKER_JOB_MAX_ATTEMPTS=3
WORKER_RABBITMQ_CONNECT_RETRIES=20
WORKER_RABBITMQ_RETRY_DELAY_SECONDS=2

#############################
# Redis
#############################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_JOB_KEY_PREFIX=job_status

#############################
# Observability (optional)
#############################
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=Documentation Helper
LANGSMITH_API_KEY=
